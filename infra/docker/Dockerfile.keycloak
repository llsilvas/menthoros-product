FROM quay.io/keycloak/keycloak:23.0.0 AS builder

USER root

# Pre-build Keycloak image for production (avoids build at runtime)
RUN /opt/keycloak/bin/kc.sh build

# ── Final Stage ────────────────────────────────────────────────────────────
FROM quay.io/keycloak/keycloak:23.0.0

COPY --from=builder /opt/keycloak/lib /opt/keycloak/lib

USER 1000

# Run Keycloak in production mode (no build needed)
ENTRYPOINT ["/opt/keycloak/bin/kc.sh"]
CMD ["start"]
