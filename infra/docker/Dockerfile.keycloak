FROM quay.io/keycloak/keycloak:23.0.0

USER root

# Create startup script correctly with proper line breaks
RUN printf '#!/bin/bash\nset -e\nexec /opt/keycloak/bin/kc.sh start' > /opt/keycloak/start.sh && \
    chmod +x /opt/keycloak/start.sh && \
    cat /opt/keycloak/start.sh

USER 1000

# Run Keycloak in production mode
ENTRYPOINT ["/bin/bash", "-c", "/opt/keycloak/bin/kc.sh start"]
